  "keyFeatures": [
    "Enterprise SIP trunking with global PSTN connectivity",
    "Programmable Voice API for outbound/inbound call control",
    "Voice XML for dynamic IVR and call flow automation",
    "Real-time audio streaming via WebSockets",
    "AI voice agent integrations (VAPI, Retell AI, ElevenLabs, LiveKit, Pipecat)",
    "Call recording, transcription, and CDR access",
    "Conference calling and multi-party call management",
    "WhatsApp Business messaging and campaigns",
    "Sub-account and partner reseller management",
    "Official SDKs for Node.js, Python, Ruby, Go, and C#"
  ],
  "publicApiSurface": [
    "POST /v1/Account/{auth_id}/Call/ — make outbound call",
    "DELETE /v1/Account/{auth_id}/Call/{call_uuid}/ — hang up call",
    "POST /v1/Account/{auth_id}/Call/{call_uuid}/Transfer/ — transfer call",
    "GET /v1/Account/{auth_id}/Call/ — list live calls",
    "POST /v1/Account/{auth_id}/Application/ — create application",
    "POST /v1/Account/{auth_id}/Conference/ — manage conferences",
    "GET /v1/Account/{auth_id}/Recording/ — list recordings",
    "POST /v1/trunk/ — create SIP trunk",
    "POST /v1/trunk/{trunk_id}/credential/ — create trunk credential",
    "GET /v1/Account/{auth_id}/PhoneNumber/ — list phone numbers",
    "POST /v1/Account/{auth_id}/SubAccount/ — create sub-account",
    "POST /v1/Account/{auth_id}/AudioStream/ — start audio stream",
    "POST /partner/customers — create partner customer",
    "POST /partner/balance/transfer — transfer balance to customer",
    "GET /partner/cdrs — retrieve customer CDRs"
  ]
